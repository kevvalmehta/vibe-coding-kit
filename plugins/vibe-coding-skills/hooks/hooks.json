{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/tdd_guard.py\"",
            "timeout": 60,
            "statusMessage": "TDD-Guard checking..."
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/destructive_action_gate.py\"",
            "timeout": 15,
            "statusMessage": "Checking for destructive changes..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/destructive_action_gate.py\"",
            "timeout": 15,
            "statusMessage": "Checking for destructive commands..."
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/spec_drift_warn.py\"",
            "timeout": 15,
            "statusMessage": "Checking spec drift..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/scripts/capture-lessons.ps1\"",
            "timeout": 10,
            "statusMessage": "Capturing lessons..."
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/done_claim_verifier.py\"",
            "timeout": 15,
            "statusMessage": "Verifying done-claims..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/recommender_nudge.py\"",
            "timeout": 10,
            "statusMessage": "Checking recommender..."
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/conductor_greeting.py\"",
            "timeout": 10,
            "statusMessage": "Checking Conductor..."
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/lessons_injector.py\"",
            "timeout": 10,
            "statusMessage": "Loading the Scar Log..."
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/regrounding.py\"",
            "timeout": 15,
            "statusMessage": "Re-grounding in git state..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/ruff_on_edit.py\"",
            "timeout": 30,
            "statusMessage": "Ruff auto-fixing..."
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/import_reality_check.py\"",
            "timeout": 30,
            "statusMessage": "Checking imports are real..."
          }
        ]
      }
    ]
  }
}
